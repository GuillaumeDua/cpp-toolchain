{
    "name": "cpp-toolchain-dev",
    "dockerComposeFile": "./docker-compose.yaml",
    "service": "cpp-toolchain-dev",
    "workspaceFolder": "/workspace",
    // "remoteUser": "vscodeuser", // no default user in the base image; opt-in via the ssh_support profile
    "shutdownAction": "stopCompose",
    "overrideCommand": true,
    "features": {
        // see https://github.com/devcontainers/features/tree/main/src
        // SSH is intentionally not added here: it's provided by the opt-in
        // ssh_support.dockerfile stage, which also works for non-VS Code
        // consumers of the published image (see README > Remote access).
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh",
                "terminal.integrated.profiles.linux": { "zsh": { "path": "/bin/zsh" } },
                "remote.SSH.showLoginTerminal": true
            },
            "extensions": [
                // remote
                "ms-vscode.remote-explorer",
                "ms-vscode-remote.remote-ssh-edit",
                "ms-vscode.remote-server",
                "ms-vscode-remote.vscode-remote-extensionpack",
                "ms-vscode-remote.remote-ssh",
                // dev
                "ms-vscode.cpptools",
                "twxs.cmake",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools-extension-pack",
                "fredericbonnet.cmake-test-adapter",
                "josetr.cmake-language-support-vscode",
                // misc
                "Gruntfuggly.todo-tree",
                "enkia.tokyo-night",
                "ms-azuretools.vscode-docker",
                "github.vscode-github-actions",
                // documentation
                "DavidAnson.vscode-markdownlint",
                "yzhang.markdown-all-in-one",
                "TakumiI.markdowntable",
                "cschlosser.doxdocgen"
            ]
        },
        "postCreateCommand": {
            "git-safe-dir-workspace": "git config --global --add safe.directory /workspace"
        }
    }
}
// features: https://github.com/devcontainers/features
